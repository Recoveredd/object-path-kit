{
  "name": "object-path-kit",
  "version": "0.1.2",
  "description": "Parse, normalize and safely access JavaScript object paths.",
  "type": "module",
  "license": "MIT",
  "author": "Recoveredd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Recoveredd/object-path-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Recoveredd/object-path-kit/issues"
  },
  "homepage": "https://github.com/Recoveredd/object-path-kit#readme",
  "keywords": [
    "object",
    "path",
    "dot",
    "json",
    "parse",
    "get",
    "immutable",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
